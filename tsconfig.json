{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": ".",
        "resolveJsonModule": true
    },
    "include": [
        "prisma/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}