# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/awaasdirect

# ─── JWT ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-super-secret-32chars-min
JWT_REFRESH_SECRET=change-me-refresh-super-secret-32chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS S3 ──────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=awaasdirect-assets

# ─── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Resend (Email) ───────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@awaasdirect.in

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
